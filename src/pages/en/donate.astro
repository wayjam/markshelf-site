---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslation } from '../../i18n/utils';
import { config } from '../../config';

const lang = 'en';
const t = useTranslation(lang);

const cryptoColors: Record<string, string> = {
  BTC: '#F7931A',
  SOL: '#9945FF',
  'USDC (ERC-20)': '#2775CA',
};

const cryptoWallets = config.donate.crypto.map((c) => ({
  name: c.name,
  address: c.address,
  color: cryptoColors[c.name] || '#6B7280',
}));
---

<BaseLayout
  title="Support MarkShelf — Donate"
  description="Support MarkShelf development. Your contribution helps us maintain and improve this free bookmark manager."
  lang="en"
  currentPath="/donate/"
>
  <section class="pt-28 pb-24 relative">
    <!-- Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full bg-brand-amber/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Page Header -->
      <div class="text-center mb-16 fade-in-up">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">{t('donate.title')}</span>
        </h1>
        <p class="text-base sm:text-lg text-text-secondary max-w-2xl mx-auto">
          {t('donate.subtitle')}
        </p>
      </div>

      <!-- Buy Me a Coffee -->
      <div class="glass-card rounded-xl p-6 flex flex-col sm:flex-row sm:items-center gap-5 mb-6 fade-in-up">
        <div class="text-yellow-400 shrink-0">
          <Icon name="simple-icons:buymeacoffee" class="w-10 h-10" />
        </div>
        <div class="flex-1">
          <h3 class="text-base font-semibold text-text-primary mb-1">
            {t('donate.coffee.title')}
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            {t('donate.coffee.desc')}
          </p>
        </div>
        <a
          href={config.donate.buyMeCoffee}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-brand-amber text-white text-sm font-semibold shadow-lg shadow-brand-amber/15 hover:shadow-brand-amber/30 hover:scale-[1.02] transition-all duration-300 shrink-0"
        >
          {t('donate.coffee.cta')}
          <Icon name="heroicons:arrow-top-right-on-square" class="w-4 h-4" />
        </a>
      </div>

      <!-- Crypto Wallets -->
      <div class="glass-card rounded-xl p-6 mb-16 fade-in-up" style="transition-delay: 100ms">
        <div class="flex items-center gap-3 mb-5">
          <Icon name="heroicons:currency-dollar" class="w-8 h-8 text-brand-ice" />
          <div>
            <h3 class="text-base font-semibold text-text-primary">
              {t('donate.crypto.title')}
            </h3>
            <p class="text-sm text-text-secondary">
              {t('donate.crypto.desc')}
            </p>
          </div>
        </div>
        <div class="space-y-3">
          {cryptoWallets.map((wallet) => (
            <div class="flex items-center gap-3 p-3 rounded-lg bg-white/5 group">
              <span
                class="w-2.5 h-2.5 rounded-full shrink-0"
                style={`background-color: ${wallet.color}`}
              ></span>
              <span class="text-sm font-medium text-text-primary whitespace-nowrap">{wallet.name}</span>
              <code class="text-xs text-text-secondary font-mono truncate flex-1">{wallet.address}</code>
              <button
                class="copy-btn shrink-0 px-3 py-1 rounded text-xs font-medium bg-white/5 text-text-secondary hover:bg-white/10 hover:text-text-primary transition-colors"
                data-address={wallet.address}
              >
                Copy
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- Thank You -->
      <div class="text-center glass-card rounded-2xl p-8 sm:p-10 fade-in-up">
        <div class="text-4xl mb-4">💖</div>
        <h2 class="text-xl font-bold text-text-primary mb-3">{t('donate.thanks')}</h2>
        <p class="text-sm text-text-secondary leading-relaxed max-w-lg mx-auto">
          {t('donate.thanks.desc')}
        </p>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const address = btn.getAttribute('data-address');
        if (address) {
          await navigator.clipboard.writeText(address);
          const original = btn.textContent;
          btn.textContent = '✓ Copied!';
          btn.classList.add('text-green-400');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('text-green-400');
          }, 2000);
        }
      });
    });
  </script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslation } from '../../i18n/utils';
import { config } from '../../config';

const lang = 'en';
const t = useTranslation(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const browsers = [
  {
    key: 'chrome',
    name: t('getStarted.chrome.title'),
    desc: t('getStarted.chrome.desc'),
    cta: t('getStarted.chrome.cta'),
    href: config.stores.chrome,
    icon: `<svg class="w-10 h-10" viewBox="0 0 24 24" fill="none">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#4285F4"/>
      <path d="M17.5 12c0-.5-.1-1-.2-1.5H12v3h5.3c-.2 1.1-.8 2-1.7 2.6l2.9 2.2c-.7-.6-1.5-1.4-1.5-2.3z" fill="#34A853"/>
      <path d="M12 19c-1.7 0-3.2-.6-4.3-1.6l-2.9 2.2c1.7 1.1 3.9 1.7 6.2 1.7 2.4 0 4.6-.8 6.2-1.7l-2.9-2.2c-1.1.8-2.5 1.3-3.3 1.3z" fill="#FBBC05"/>
      <path d="M7.7 14.4c-.2-.6-.3-1.3-.3-2s.1-1.4.3-2l-4-3.1C3.1 8.4 3 10.2 3 12s.1 3.6.7 5.3l4.1-3.2c-.2-.5-.1-.9-.1-1.3z" fill="#EA4335"/>
    </svg>`,
    available: true,
  },
  {
    key: 'edge',
    name: t('getStarted.edge.title'),
    desc: t('getStarted.edge.desc'),
    cta: t('getStarted.edge.cta'),
    href: config.stores.edge,
    icon: `<svg class="w-10 h-10" viewBox="0 0 24 24" fill="none">
      <path d="M3.5 3.5C5.4 2.3 7.8 1.7 10.2 1.9c3.5.3 6.7 2.6 8 6 1.3-1.3 2-3.1 2-5 0-4.4-3.6-8-8.7-8-1.9 0-3.7.6-5.2 1.8l.4.4 4.3 4.3-4.3 4.3c-1.2-1.6-1.8-3.4-1.8-5.3 0-2.4.8-4.7 2.1-6.5l.5.5z" fill="#0078D4"/>
      <path d="M3.5 20.5l4.3-4.3 4.3-4.3-4.3-4.3c-1.6 1.2-2.8 3-3.5 5-.3 1-.5 2-.5 3 0 1.9.7 3.6 1.8 5l.4.3c-1.2-1.8-1.8-3.9-1.8-6.1 0-1.2.2-2.4.6-3.5l.3.3" fill="#50E6FF"/>
    </svg>`,
    available: true,
  },
  {
    key: 'firefox',
    name: t('getStarted.firefox.title'),
    desc: t('getStarted.firefox.desc'),
    cta: t('getStarted.firefox.cta'),
    href: config.stores.firefox,
    icon: `<svg class="w-10 h-10" viewBox="0 0 24 24" fill="none">
      <path d="M23.3 11.5c0-2.3-.7-4.5-2-6.4-1.4-1.9-3.5-3.2-5.9-3.6-.5 1.3-.8 2.7-.8 4.2 0 3.7 1.9 6.9 4.7 8.7-.1-.5-.2-1-.2-1.5 0-2.1 1.1-3.9 2.7-4.9-.4-.6-1-1.5-1.2-2.2.3.1.5.2.8.3 1 .4 2 .6 3.1.3 1.1-.3 2-1 2.6-2 .5.2 1 .3 1.6.3.3 0 .5 0 .8-.1-.4-1.1-1-2-1.6-2.8z" fill="#FF6611"/>
      <path d="M12 22c-1.3 0-2.5-.3-3.6-.8.2-.3.5-.6.8-.9 1.2.5 2.5.8 3.9.8 1.3 0 2.5-.2 3.6-.6.3.2.6.4.9.6-1.3.7-2.8 1.1-4.4 1.1-.7 0-1.4-.1-2-.2z" fill="#FF9400"/>
      <path d="M10.4 16.3c-1.3-.4-2.5-.9-3.5-1.6.7-.6 1.3-1.3 1.7-2-.7.2-1.4.4-2 .7-.6-1.1-1.4-2-2.3-2.7.4-.4.9-.7 1.4-.9-.2.4-.3.9-.3 1.4 0 2.1 1.2 3.9 2.9 4.8.2-.3.4-.6.6-1 .1.5.2 1 .2 1.5 0 .5 0 1-.1 1.5-1.1-.5-2-1.2-2.7-2.1z" fill="#FF6611"/>
      <path d="M16.5 13.5c0-.6-.1-1.2-.4-1.8-.8-1.5-2.3-2.5-4-2.5-.4 0-.8.1-1.2.2-.2-.2-.4-.4-.6-.6 1.5-.6 3.2-.9 4.9-.6 1.8.3 3.4 1.2 4.6 2.5-.4-.1-.8-.2-1.2-.2-1.5 0-2.9.6-4 1.7.1-.1.2-.1.3-.2-.2.3-.4.7-.4 1.1 0 .9.5 1.7 1.2 2.2-.3.1-.6.2-1 .2-.4 0-.8-.1-1.2-.3.4.6.9 1.1 1.5 1.5-1 .5-2.1.8-3.3.8-.4 0-.8 0-1.2-.1.3.4.7.7 1.1 1 1.4-1.4 3.2-2.3 5.2-2.4 1.1 0 2.1.2 3.1.6-.1-.3-.2-.6-.3-.9.5.3 1 .6 1.4 1-1.5 1.3-3.4 2.2-5.5 2.4z" fill="#FF9400"/>
    </svg>`,
    available: false,
  },
];
---

<BaseLayout
  title="Get Started — MarkShelf"
  description="Install MarkShelf on Chrome, Firefox, or Edge"
  lang="en"
  currentPath="/get-started/"
>
  <section class="pt-28 pb-24 relative">
    <!-- Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[300px] rounded-full bg-brand-amber/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Page Header -->
      <div class="text-center mb-16 fade-in-up">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">{t('getStarted.title')}</span>
        </h1>
        <p class="text-base sm:text-lg text-text-secondary max-w-2xl mx-auto">
          {t('getStarted.subtitle')}
        </p>
      </div>

      <!-- Browser Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {browsers.map((browser, i) => (
          <div
            class="glass-card rounded-xl p-6 flex flex-col fade-in-up"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="mb-4">
              <Fragment set:html={browser.icon} />
            </div>
            <h3 class="text-base font-semibold text-text-primary mb-2">
              {browser.name}
            </h3>
            <p class="text-sm text-text-secondary leading-relaxed mb-5 flex-1">
              {browser.desc}
            </p>
            {browser.available ? (
              <a
                href={browser.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-brand-amber text-white text-sm font-semibold shadow-lg shadow-brand-amber/15 hover:shadow-brand-amber/30 hover:scale-[1.02] transition-all duration-300"
              >
                {browser.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : (
              <div class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-lg bg-white/5 text-text-muted text-sm font-medium">
                {browser.cta}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

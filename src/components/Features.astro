---
import { Icon } from 'astro-icon/components';
import type { Language } from '../i18n/ui';
import { useTranslation } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslation(lang);

const features = [
  {
    icon: 'heroicons:beaker',
    titleKey: 'features.ai-classify.title' as const,
    descKey: 'features.ai-classify.desc' as const,
  },
  {
    icon: 'heroicons:squares-2x2',
    titleKey: 'features.ai-organize.title' as const,
    descKey: 'features.ai-organize.desc' as const,
  },
  {
    icon: 'heroicons:tag',
    titleKey: 'features.ai-tags.title' as const,
    descKey: 'features.ai-tags.desc' as const,
  },
  {
    icon: 'heroicons:document-text',
    titleKey: 'features.ai-summary.title' as const,
    descKey: 'features.ai-summary.desc' as const,
  },
  {
    icon: 'heroicons:magnifying-glass',
    titleKey: 'features.semantic-search.title' as const,
    descKey: 'features.semantic-search.desc' as const,
  },
  {
    icon: 'heroicons:arrows-right-left',
    titleKey: 'features.diff-view.title' as const,
    descKey: 'features.diff-view.desc' as const,
  },
  {
    icon: 'heroicons:command-line',
    titleKey: 'features.commander.title' as const,
    descKey: 'features.commander.desc' as const,
  },
  {
    icon: 'heroicons:shield-check',
    titleKey: 'features.health-check.title' as const,
    descKey: 'features.health-check.desc' as const,
  },
  {
    icon: 'heroicons:arrow-uturn-left',
    titleKey: 'features.undo-redo.title' as const,
    descKey: 'features.undo-redo.desc' as const,
  },
  {
    icon: 'heroicons:cog-8-tooth',
    titleKey: 'features.auto-process.title' as const,
    descKey: 'features.auto-process.desc' as const,
  },
  {
    icon: 'heroicons:arrow-up-tray',
    titleKey: 'features.import-export.title' as const,
    descKey: 'features.import-export.desc' as const,
  },
  {
    icon: 'heroicons:lock-closed',
    titleKey: 'features.privacy.title' as const,
    descKey: 'features.privacy.desc' as const,
  },
];
---

<section id="features" class="py-24 sm:py-32 relative">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16 fade-in-up">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        <span class="gradient-text">{t('features.title')}</span>
      </h2>
      <p class="text-text-secondary text-base sm:text-lg max-w-2xl mx-auto">
        {t('features.subtitle')}
      </p>
    </div>

    <!-- Feature Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 lg:gap-5">
      {features.map((feature, i) => (
        <div
          class="glass-card rounded-xl p-5 fade-in-up"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="w-10 h-10 rounded-lg bg-brand-blue/10 flex items-center justify-center text-brand-ice mb-3.5">
            <Icon name={feature.icon} class="w-6 h-6" />
          </div>
          <h3 class="text-sm font-semibold text-text-primary mb-1.5">
            {t(feature.titleKey)}
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">
            {t(feature.descKey)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

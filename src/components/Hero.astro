---
import { Icon } from 'astro-icon/components';
import type { Language } from '../i18n/ui';
import { useTranslation } from '../i18n/utils';
import { config } from '../config';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslation(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-16">
  <!-- Background Glows -->
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>

  <!-- Grid Pattern Overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(rgba(90,155,214,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(90,155,214,0.3) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Logo -->
    <div class="mb-8 fade-in-up">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-bg-tertiary/50 glow-border">
        <img
          src={`${base}/logo.png`}
          alt="MarkShelf Logo"
          class="w-14 h-14 rounded-xl"
          onerror="this.parentElement.innerHTML='<span class=\'text-3xl\'>📚</span>'"
        />
      </div>
    </div>

    <!-- Title -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 fade-in-up">
      <span class="gradient-text">{t('hero.title')}</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-base sm:text-lg md:text-xl text-text-secondary leading-relaxed max-w-2xl mx-auto mb-10 fade-in-up">
      {t('hero.subtitle')}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in-up">
      <a
        href={`${base}/get-started/`}
        class="group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-xl bg-brand-amber text-white font-semibold text-sm shadow-lg shadow-brand-amber/20 hover:shadow-brand-amber/40 hover:scale-[1.02] transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        {t('hero.cta.getStarted')}
      </a>
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-16 fade-in-up">
      <div class="inline-flex flex-col items-center gap-2 text-text-muted animate-bounce">
        <span class="text-xs">{lang === 'zh' ? '向下滚动' : 'Scroll Down'}</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </div>
</section>
